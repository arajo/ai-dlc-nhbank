# Application
APP_NAME=Table Order API
DEBUG=true
LOG_LEVEL=INFO

# Database
DATABASE_URL=sqlite+aiosqlite:///./table_order.db

# JWT
SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=16

# CORS
CORS_ORIGINS=http://localhost:5173

# Server
HOST=0.0.0.0
PORT=8000

# Security
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=5

# SSE
SSE_MAX_CONNECTIONS=20
SSE_HEARTBEAT_SECONDS=30

# Data Retention
ORDER_HISTORY_RETENTION_DAYS=30
BACKUP_RETENTION_DAYS=7
